{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mcp-ads/schemas/variables.schema.json",
  "title": "Lista blanca de variables ADS",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "ads_path", "plc_type", "access"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9_\\-]+$",
        "description": "Identificador estable expuesto a las herramientas MCP"
      },
      "ads_path": {
        "type": "string",
        "minLength": 1,
        "description": "Ruta simbólica TwinCAT (p. ej. MAIN.nContador)"
      },
      "plc_type": {
        "type": "string",
        "enum": [
          "BOOL",
          "BYTE",
          "WORD",
          "DWORD",
          "SINT",
          "USINT",
          "INT",
          "UINT",
          "DINT",
          "UDINT",
          "REAL",
          "LREAL",
          "STRING"
        ]
      },
      "access": {
        "type": "string",
        "enum": ["read", "read_write"]
      },
      "string_length": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "description": "Obligatorio si plc_type es STRING (tamaño en PLC)"
      }
    },
    "allOf": [
      {
        "if": {
          "properties": { "plc_type": { "const": "STRING" } },
          "required": ["plc_type"]
        },
        "then": { "required": ["string_length"] }
      }
    ]
  }
}
